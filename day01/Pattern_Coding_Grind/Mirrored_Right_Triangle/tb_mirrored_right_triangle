module tb_mirrored_right_triangle;
	integer i,j,k;
 	integer N = 5;
	initial begin
		$display("------------------------------------------------------------------------------------------------");
		$display("Mirrored Right Triangle Generation: ");
		
		for(i = 1; i < N; i = i + 1) begin 
			for (j = 1; j <= N - i; j = j + 1) begin
				$write(" ");
			end
			for(k = 1; k <= i; k = k + 1) begin
				$write("*");
			end
			$display("");
		end
		$display("------------------------------------------------------------------------------------------------");
		$finish;
	end
endmodule

			
